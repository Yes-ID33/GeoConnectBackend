    "/api/AccionLugar/mis-acciones/{idUsuario}": {
      "get": {
        "tags": [
          "AccionLugar"
        ],
        "summary": "Método para obtener todos lugares con acciones asignadas de un usuario",
        "parameters": [
          {
            "name": "idUsuario",
            "in": "path",
            "description": "",
            "required": true,
            "schema": {
              "type": "integer",
              "format": "int32"
            }
          },
          {
            "name": "tipoAccion",
            "in": "query",
            "description": "",
            "schema": {
              "type": "string"
            }
          },
          {
            "name": "ordenarPorLugar",
            "in": "query",
            "description": "",
            "schema": {
              "type": "boolean",
              "default": false
            }
          }
        ],
        "responses": {
          "200": {
            "description": "OK"
          }
        }
      }
    },
